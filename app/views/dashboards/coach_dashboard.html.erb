<div class="min-h-screen bg-slate-50 flex">
  <%# Sidebar Simulation (Optional, for layout structure) %>
  <aside class="w-64 bg-indigo-900 text-white hidden md:block">
    <div class="p-6">
      <h2 class="text-2xl font-bold tracking-tight">FatLoss Pro</h2>
    </div>
    <nav class="mt-6 px-4 space-y-2">
      <a href="#" class="block px-4 py-2 bg-indigo-800 rounded-lg text-sm font-medium">Dashboard</a>
      <%= link_to 'Flash Sales', flash_campaigns_path, class: "block px-4 py-2 hover:bg-indigo-800 rounded-lg text-sm font-medium transition" %>
    </nav>
  </aside>

  <%# Main Content Area %>
  <main class="flex-1 p-4 md:p-10">
    <div class="max-w-5xl mx-auto">
      
      <%# Top Header %>
      <header class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-10">
        <div>
          <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Coach Overview</h1>
          <p class="text-slate-500 mt-1">Managing <%= current_tenant.name %> training facility.</p>
        </div>
        
        <%# Invite Box %>
        <div class="bg-indigo-50 border border-indigo-100 p-4 rounded-2xl flex items-center gap-4">
          <div class="bg-indigo-500 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
              <path d="M8 9a3 3 0 100-6 3 3 0 000 6zM8 11a6 6 0 016 6H2a6 6 0 016-6zM16 7a1 1 0 10-2 0v1h-1a1 1 0 100 2h1v1a1 1 0 102 0v-1h1a1 1 0 100-2h1V7z" />
            </svg>
          </div>
          <div>
            <span class="text-xs font-bold text-indigo-400 uppercase tracking-wider">Client Invite Link</span>
            <div class="flex items-center gap-2">
              <code class="text-sm font-mono text-indigo-700 bg-white px-2 py-1 rounded border border-indigo-200">
                <%= signup_url(token: current_tenant.invitation_token) %>
              </code>
            </div>
          </div>
        </div>
      </header>

      <%# Stats Grid %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        <div class="bg-white p-6 rounded-3xl shadow-sm border border-slate-200">
          <p class="text-sm font-medium text-slate-500">Active Flash Sales</p>
          <p class="text-4xl font-black text-indigo-600 mt-2">
            <%= current_tenant.flash_campaigns.count %>
          </p>
          <div class="mt-4 flex items-center text-xs text-emerald-600 font-bold">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 10l7-7m0 0l7 7m-7-7v18" />
            </svg>
            System Active
          </div>
        </div>
      </div>

      <%# Clients List Table %>
      <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between bg-white">
          <h2 class="text-xl font-bold text-slate-800">Your Clients</h2>
          <span class="bg-slate-100 text-slate-600 text-xs font-bold px-3 py-1 rounded-full">
            <%= @clients.count %> Total
          </span>
        </div>
        
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead>
              <tr class="text-slate-400 text-xs uppercase tracking-widest font-semibold border-b border-slate-50">
                <th class="px-8 py-4">Full Name</th>
                <th class="px-8 py-4">Contact</th>
                <th class="px-8 py-4 text-right">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% @clients.each do |client| %>
                <tr class="hover:bg-indigo-50/30 transition-colors group">
                  <td class="px-8 py-5">
                    <div class="flex items-center gap-3">
                      <div class="h-10 w-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 font-bold group-hover:bg-indigo-100 group-hover:text-indigo-600 transition">
                        <%= client.name[0] %>
                      </div>
                      <span class="font-bold text-slate-700"><%= client.name %></span>
                    </div>
                  </td>
                  <td class="px-8 py-5 text-slate-500 text-sm">
                    <%= client.email %>
                  </td>
                  <td class="px-8 py-5 text-right"></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</div>