<div class="min-h-screen bg-gray-50 pb-12">
  <div class="max-w-md mx-auto bg-white shadow-lg overflow-hidden md:rounded-b-3xl">
    <% if @campaign.product_image.attached? %>
        <%= image_tag @campaign.product_image.variant(
              resize_to_limit: [ 2000, 2000 ],
              saver: { quality: 95, strip: true }
            ),
            class: "w-full h-80 object-cover",
            alt: @campaign.title %>
    <% else %>
      <div class="w-full h-64 bg-gray-200 flex items-center justify-center text-gray-400">尚無圖片</div>
    <% end %>

    <div class="p-6">
      <div class="flex justify-between items-start mb-4">
        <h1 class="text-2xl font-black text-gray-900 leading-tight"><%= @campaign.title %></h1>
        <div class="text-right">
          <span class="text-sm text-gray-400 block line-through">限時特價</span>
          <span class="text-2xl font-bold text-red-600">NT$ <%= @campaign.price %></span>
        </div>
      </div>

      <div class="bg-red-50 rounded-2xl p-4 border border-red-100 mb-8">
        <div class="flex items-center justify-between mb-2">
          <span class="text-red-700 font-bold flex items-center gap-1">
            🔥 剩 <%= @campaign.cached_remaining_stock %> 個！
          </span>

          <span class="text-xs text-red-500 font-medium bg-white px-2 py-1 rounded-full shadow-sm">
            熱賣中
          </span>
        </div>

        <div class="w-full bg-red-200 h-2 rounded-full overflow-hidden">
          <% percentage = (@campaign.remaining_stock.to_f / @campaign.total_stock * 100).to_i rescue 0 %>
          <div class="bg-red-600 h-full transition-all duration-500" style="width: <%= percentage %>%"></div>
        </div>

        <p class="text-sm text-red-600 mt-3 font-medium text-center">
          截止時間：<%= @campaign.expired_at.strftime("%m/%d %H:%M") %>
        </p>
      </div>

      <div class="space-y-4">
        <h3 class="text-lg font-bold text-gray-800 mb-4 text-center">立即搶購</h3>

        <%= form_with(model: [ @campaign, @order ], url: campaign_sale_flash_orders_path(@campaign), class: "space-y-4") do |f| %>
          <div>
            <%= f.text_field :name, required: true, placeholder: "姓名",
                class: "w-full px-4 py-4 bg-gray-50 border-0 rounded-2xl focus:ring-2 focus:ring-black outline-none transition" %>
          </div>

          <div>
            <%= f.email_field :email, required: true, placeholder: "電子郵件",
                class: "w-full px-4 py-4 bg-gray-50 border-0 rounded-2xl focus:ring-2 focus:ring-black outline-none transition" %>
          </div>

          <div>
            <%= f.text_field :phone, required: true, placeholder: "聯絡電話",
                class: "w-full px-4 py-4 bg-gray-50 border-0 rounded-2xl focus:ring-2 focus:ring-black outline-none transition" %>
          </div>

          <%= f.submit "立即搶購 🚀",
              class: "w-full bg-black hover:bg-gray-800 text-white font-black py-5 rounded-2xl shadow-xl transition-all transform active:scale-95 text-lg cursor-pointer" %>
        <% end %>
      </div>

      <p class="text-center text-xs text-gray-400 mt-6">
        由 FlashSale Pro 提供安全結帳
      </p>
    </div>
  </div>
</div>
