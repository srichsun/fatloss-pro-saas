<div class="max-w-2xl mx-auto p-8">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">新增限時搶購</h1>
    <p class="text-gray-500 mt-2">為你的粉絲建立一檔限時優惠。</p>
  </div>

  <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
    <%= form_with(model: @flash_campaign, class: "space-y-6") do |f| %>

      <div>
        <%= f.label :title, "商品名稱", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.text_field :title,
            placeholder: "例如：夏季限定 1 對 1 私訓",
            class: "w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" %>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <%= f.label :price, "售價（TWD）", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.number_field :price,
              class: "w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 outline-none" %>
        </div>

        <div>
          <%= f.label :total_stock, "庫存數量", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.number_field :total_stock,
              class: "w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 outline-none" %>
        </div>
      </div>

      <div>
        <%= f.label :expired_at, "截止時間", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.datetime_local_field :expired_at,
            class: "w-full px-4 py-3 rounded-xl border border-gray-200 focus:ring-2 focus:ring-blue-500 outline-none" %>
      </div>

      <div class="bg-gray-50 p-6 rounded-2xl border-2 border-dashed border-gray-200">
        <%= f.label :product_image, "商品封面圖", class: "block text-sm font-semibold text-gray-700 mb-2" %>
        <%= f.file_field :product_image,
            class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 cursor-pointer" %>
      </div>

      <div class="pt-4">
        <%= f.submit "開始搶購",
            class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-200 transition-all transform active:scale-[0.98]" %>

        <%= link_to "取消並返回", flash_campaigns_path,
            class: "block text-center mt-4 text-sm text-gray-400 hover:text-gray-600" %>
      </div>

    <% end %>
  </div>
</div>
