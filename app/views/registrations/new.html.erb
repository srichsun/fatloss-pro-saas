<%# app/views/registrations/new.html.erb %>
<div class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="text-center text-3xl font-extrabold text-gray-900">Start Your Coaching Business</h2>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10">
      <%= form_with model: @tenant, url: signup_path, class: "space-y-6" do |f| %>
        
        <%# Tenant Fields (The Shop) %>
        <div class="border-b border-gray-200 pb-4 mb-4">
          <h3 class="text-lg font-medium text-gray-900">Step 1: Your Gym Info</h3>
          <div class="mt-4">
            <%= f.label :name, "Gym/Coach Name", class: "block text-sm font-medium text-gray-700" %>
            <%= f.text_field :name, name: "tenant[name]", placeholder: "e.g. Iron Gym", class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>
          <div class="mt-4">
            <%= f.label :subdomain, "Unique URL Path", class: "block text-sm font-medium text-gray-700" %>
            <div class="mt-1 flex rounded-md shadow-sm">
              <span class="inline-flex items-center px-3 rounded-l-md border border-r-0 border-gray-300 bg-gray-50 text-gray-500 text-sm">/tenants/</span>
              <%= f.text_field :subdomain, name: "tenant[subdomain]", placeholder: "iron-gym", class: "flex-1 min-w-0 block w-full px-3 py-2 border border-gray-300 rounded-none rounded-r-md focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
            </div>
          </div>
        </div>

        <%# User Fields (The Coach) %>
        <div>
          <h3 class="text-lg font-medium text-gray-900">Step 2: Your Admin Account</h3>
          <div class="mt-4">
            <%= label_tag "user[email]", "Email Address", class: "block text-sm font-medium text-gray-700" %>
            <%= email_field_tag "user[email]", nil, required: true, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>
          <div class="mt-4">
            <%= label_tag "user[password]", "Password", class: "block text-sm font-medium text-gray-700" %>
            <%= password_field_tag "user[password]", nil, required: true, class: "mt-1 block w-full border border-gray-300 rounded-md shadow-sm py-2 px-3 focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>
        </div>

        <div>
          <%= f.submit "Create My Gym", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
        </div>
      <% end %>
    </div>
  </div>
</div>