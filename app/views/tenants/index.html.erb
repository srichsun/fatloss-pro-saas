<div class="bg-gray-50 min-h-screen py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
        Fat Loss Pro: Choose Your Coach
      </h2>
      <p class="mt-4 text-xl text-gray-500">
        Enter a dedicated coaching space to start your transformation.
      </p>
    </div>

    <div class="mt-12 grid gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      <% @tenants.each do |tenant| %>
        <div class="bg-white overflow-hidden shadow rounded-lg border hover:shadow-lg transition">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-gray-900"><%= tenant.name %></h3>
            <p class="mt-1 text-sm text-gray-500">Subdomain: <%= tenant.subdomain %></p>
            <div class="mt-4">
              <%= link_to "Enter Room", coach_room_path(tenant.subdomain), 
                  class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>